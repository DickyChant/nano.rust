analysis muon_hist_weight_systematic year Run2018;

weight nominal;
systematic muon_weight kind weight up 2.0 down 0.5;

object good_muon : Muon {
  pt > 30 GeV;
  abs(eta) < 2.4;
}

region signal {
  count(good_muon) >= 1;
}

define n_good_muon = count(good_muon);

output n_good_muon;

histogram n_good_muon_hist {
  expr = count(good_muon);
  bins = 5;
  range = [0.0, 5.0];
}
