universe = vanilla
executable = process.sh

should_transfer_files = YES
when_to_transfer_output = ON_EXIT_OR_EVICT
transfer_input_files = repo.tar.gz,config_snapshot.yaml,job_manifest.json
transfer_output_files = dummy.cc

environment = "DOWNLOAD_FILE=false"
output = logs/job_$(Cluster)_$(Process).out
error = logs/job_$(Cluster)_$(Process).err
log = logs/job_$(Cluster).log

request_cpus = 1

arguments = $(job_index) @TREE_NAME@ @NUM_EVENTS@ config_snapshot.yaml @CHANNEL@ @VARIATIONS@
queue job_index from job_indices.txt
